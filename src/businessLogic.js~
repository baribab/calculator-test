// importa as funções do coreMath
import { sumFunction, subFunction, multFunction, divFunction } from "./coreMath.js";

// calcular média
export function calculateAverage(purchases) {
  // validações
  if (!Array.isArray(purchases)) {
    throw new Error("Entrada deve ser um array");
  }

  if (purchases.length === 0) {
    throw new Error("Array não pode estar vazio");
  }

  // soma todos os valores usando soma()
  let total = 0;

  for (let i = 0; i < purchases.length; i++) {
    total = sumFunction(total, purchases[i]);
  }

  // média = soma / quantidade
  return divFunction(total, purchases.length);
}

// calcular preço com desconto
export function calculateDiscountedPrice(price, discountPercent) {
  // validações
  if (price <= 0) {
    throw new Error("Preço deve ser maior que zero");
  }

  if (discountPercent < 0 || discountPercent > 100) {
    throw new Error("Desconto deve estar entre 0 e 100");
  }

  // valor do desconto = (price * discountPercent) / 100
  const discountValue = divFunction(multFunction(price, discountPercent), 100);

  // preço final = price - desconto
  return subFunction(price, discountValue);
}
